# Copy to .env and fill with your values. Never commit .env to git.

# Firebase (from Firebase Console > Project Settings)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=

# Google Maps (from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=

# PayPal (from developer.paypal.com > My Apps)
EXPO_PUBLIC_PAYPAL_CLIENT_ID=

# Optional: Live PayPal "Pay Now" link (works on all platforms, opens in browser)
# Create at paypal.com > Create Payment Button. Use for fixed-amount or fallback.
# EXPO_PUBLIC_PAYPAL_PAYMENT_LINK=https://www.paypal.com/ncp/payment/XXXXX

# Optional: hosted Privacy Policy URL (for app store submission)
# EXPO_PUBLIC_PRIVACY_URL=https://yoursite.com/privacy
