# Copy to .env and fill with your values. Never commit .env to git.

# Optional: Sentry crash reporting (leave unset to disable)
# EXPO_PUBLIC_SENTRY_DSN=https://...@...ingest.sentry.io/...
#
# Stops the Expo "Missing organization, project" warning and enables source maps on EAS when set:
# Slugs are in Sentry: Settings → Projects → [project] → Client Keys (project slug) and org URL.
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# For uploads only — create an EAS Secret or CI var (never commit):
# SENTRY_AUTH_TOKEN=sntrys_...
# Local ./gradlew assembleRelease without a token (avoids Sentry CLI auth error):
# SENTRY_DISABLE_AUTO_UPLOAD=true

# Firebase (from Firebase Console > Project Settings). EXPO_PUBLIC_FIREBASE_PROJECT_ID must equal
# "project_id" in android/app/google-services.json (and GoogleService-Info.plist on iOS) or ID token sync / PayPal callables fail.
# Push tokens use the EAS project UUID (app.config extra.eas.projectId), NOT the Firebase project id — do not confuse the two.
# EXPO_PUBLIC_EAS_PROJECT_ID=9d9722fe-1abf-4aea-9bb1-5bd432c3384f
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=

# Cloud Functions region for callable HTTPS (default us-central1). Must match where functions deploy.
# EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1

# Signup: omit EXPO_PUBLIC_APP_ENV or use preview/development = ID & vehicle docs optional (faster testing).
# EXPO_PUBLIC_APP_ENV=production  → full rider/driver compliance required (store-ready).

# Android phone auth: set true ONLY if you use reCAPTCHA Enterprise and need to force the web reCAPTCHA flow
# (e.g. EAS/Play key mismatch you cannot register). Default/false = Play Integrity + your SHA keys in Firebase.
# After changing, restart Metro and rebuild. eas.json EAS env uses false (see that file).
# EXPO_PUBLIC_FIREBASE_ANDROID_PHONE_USE_RECAPTCHA=false

# Google Maps (from Google Cloud Console). Restrict: Android app + package com.armada.ride + debug SHA-1.
# Blank map tiles: same GCP project as Firebase → APIs & Services → enable "Maps SDK for Android" on the key
# (often the key in google-services.json). Billing on. npm run verify:android-maps after prebuild.
EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=
# Native MapView: Maps SDK for Android + Android restriction (com.armada.ride + signing SHA-1). Prefer firebase/google-services current_key or a dedicated SDK key — do not reuse the Geocoding-only key unless it also has Maps SDK enabled.
# Optional: Directions polylines use HTTPS fetch(), not the native Maps SDK — app-restricted keys usually get REQUEST_DENIED.
EXPO_PUBLIC_GOOGLE_MAPS_DIRECTIONS_KEY=
# Optional: Geocoding API for reverse address text (pickup/drop pin). SDK-restricted Maps keys often fail from fetch(); use unrestricted key or Geocoding-only key.
EXPO_PUBLIC_GOOGLE_MAPS_GEOCODING_KEY=
# Optional: Places Autocomplete + Place Details for address suggestions (same unrestricted/server key works, or Places-only key).
# Enable Places API + (same key or) EXPO_PUBLIC_GOOGLE_MAPS_PLACES_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_PLACES_KEY=
# If Google Cloud blocks places.googleapis.com from the app (API key restricted to Android/iOS only), deploy Cloud Functions
# `placesAutocomplete` + `placesPlaceDetails` and set Functions env `GOOGLE_MAPS_PLACES_KEY` or `GOOGLE_MAPS_SERVER_KEY`
# (server key: Application restrictions = None, API restrictions = Places API New + legacy Places as needed). See functions/.env.example.
# Then either rely on
# automatic fallback when the client gets PERMISSION_DENIED, or force proxy only:
# EXPO_PUBLIC_PLACES_PREFER_FUNCTIONS=true
# Run `npm run sync-maps-key` before Gradle/Android Studio builds, or use `npm run android`
# (sync runs automatically). Full clean regen + Maps manifest injection: npm run rebuild:android
# Then install: npm run run:android — or one step: npm run rebuild:android:run
#
# One-shot local sanity check (Maps key → local.properties + Firebase file + manifest):
# npm run verify:android-otp-maps-local
#
# EAS / expo.dev builds: Maps keys must be present at prebuild time. Set EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY
# (and other EXPO_PUBLIC_* Firebase vars) in Expo → Project → Environment variables for each build profile
# (preview, production, development). Missing key → blank map tiles on the device APK/AAB.
# Local `./gradlew bundleRelease`/Android Studio uses env + android/app/secrets.properties (copy android/app/secrets.properties.example → secrets.properties).
# Gradle reads EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY from env at manifest merge after `npm run sync-maps-key` / .env loads.
# Restrict the Android Maps API key to package com.armada.ride and the SHA-1 of the keystore that signs that build
# (EAS credentials: debug / preview / production each may differ).
#
# --- Google Play AAB on your PC (no EAS credits needed) ---
# Gradle signs release with android/keystore.properties + your upload .jks (NOT the debug key — Play rejects that).
# 1) Add to .env (never commit real values):
#    ANDROID_UPLOAD_STORE_PASSWORD=
#    ANDROID_UPLOAD_KEY_ALIAS=
# Expected Play upload certificate (optional — npm run android:aab:local checks this by default).
# PLAY_UPLOAD_CERT_SHA1=DF66723F069FEB6B9360F7FC9FDE65E9B42FAA0F
# 2) One-time:  node scripts/install-play-upload-keystore.js path\to\upload.keystore.jks
#    Then:       npm run android:verify-play-upload-keystore
# 3) Build AAB: npm run android:aab:local
# → android/app/build/outputs/bundle/release/app-release.aab
# Use the same upload .jks Play Console expects, or restore it from a backup; if lost, use Play’s upload-key reset.

# PayPal: set to "false" to hide Card (PayPal) on rider payment and disable listing/vendor PayPal. Omit or "true" = on.
EXPO_PUBLIC_PAYPAL_PAYMENTS_ENABLED=true

# PayPal LIVE (production) — use the Live tab at developer.paypal.com → My Apps & Credentials
# Sandbox IDs will not work with real card charges or with verifyPayPalCapture (live API).
EXPO_PUBLIC_PAYPAL_CLIENT_ID=

# Must match Cloud Functions PAYPAL_LISTING_CURRENCY (default USD). Web PayPal SDK uses this for ride checkout.
EXPO_PUBLIC_PAYPAL_LISTING_CURRENCY=USD
# EXPO_PUBLIC_PAYPAL_PAYMENT_LINK=https://www.paypal.com/ncp/payment/XXXXX

# Rider PayPal (native): EXPO_PUBLIC_* is for the client only. Server OAuth uses Cloud Functions env:
#   PAYPAL_CLIENT_ID, PAYPAL_CLIENT_SECRET, PAYPAL_SANDBOX (true|false), PAYPAL_LISTING_CURRENCY (USD or JMD; default USD in Cloud Functions).
# Set those in GCP on each PayPal-related function OR via `firebase deploy --only functions` parameter prompts.
# Root .env is NOT read by deployed Functions — see functions/.env.example.
# If ID/secret keep "vanishing", you only updated local .env: production needs Google Cloud Console → Cloud Functions → Runtime env vars (or redeploy with params persisted); Firebase does not read H:\Armada\.env on the server.
# Rebuild the app only if EXPO_PUBLIC_FIREBASE_* was wrong for callables (must match google-services.json project_id).
# Car rental listing / vendor premium / driver subscription (Orders API) are server-side only.
# Callable functions include: createRidePayPalOrder, captureRidePayPalOrder, verifyPayPalCapture,
#   createDriverSubscriptionPayPalOrder, captureDriverSubscriptionPayPalOrder,
#   createCarRentalListingOrder, captureCarRentalListingOrder,
#   createVendorSubscriptionOrder, captureVendorSubscriptionOrder
# Firestore (admin-only writes from Functions): car_rental_listing_paypal_orders,
#   vendor_subscription_paypal_orders
# App: scheme armada (app.config.js) + expo-web-browser for PayPal return URL.

# Privacy & Terms (required for store submission – already in EAS production env)
# EXPO_PUBLIC_PRIVACY_URL=https://armada-25d8a.web.app/privacy.html
# EXPO_PUBLIC_TERMS_URL=https://armada-25d8a.web.app/terms.html
# In-app “Help center” (SupportActionRow). Defaults to /help.html on Firebase Hosting if unset.
# EXPO_PUBLIC_SUPPORT_CHAT_URL=https://armada-25d8a.web.app/help.html
