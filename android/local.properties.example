# Copy to local.properties and fill with your values.
# local.properties is gitignored - NEVER commit it.
#
# Required for Android build (Google Maps):
# GOOGLE_MAPS_API_KEY=your_google_maps_android_key_here
#
# SDK path (auto-generated by Android Studio, or set manually):
# sdk.dir=C\:\\Users\\YourUser\\AppData\\Local\\Android\\Sdk
