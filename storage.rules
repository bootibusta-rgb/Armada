rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Matches Firestore users/{uid} admin flag or role (same logic as firestore.rules)
    function isAdmin() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && (
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.admin == true
          || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
    }

    // Vehicle photos: drivers upload own; any signed-in user can read (ride UI); admins can read all
    match /vehicles/{driverId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == driverId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Car rental: listing photos + per-vehicle docs under car_rentals/{uid}/...
    match /car_rentals/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Government ID images: owner or admin read; owner write only
    match /id_verification/{userId}/{fileName} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
